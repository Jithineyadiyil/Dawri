# ────────────────────────────────────────────────────────────────────
#  SPRINT 6 — BROWSER BROADCAST (.env additions)
#  Append these lines to:  D:\xamp new\htdocs\Dawri\backend\.env
# ────────────────────────────────────────────────────────────────────

# Mux — sign up at https://www.mux.com and copy from Settings → API Access
MUX_TOKEN_ID=
MUX_TOKEN_SECRET=

# Mux webhooks — configured at Settings → Webhooks in Mux dashboard.
# For local dev, expose your XAMPP server via ngrok and use that URL.
MUX_WEBHOOK_SECRET=

# Keep TRUE while developing locally — creates free test streams that never bill.
# Flip to FALSE only when you deploy to production.
MUX_TEST_MODE=true

MUX_HTTP_TIMEOUT=10
MUX_SESSION_TTL=300
MUX_WHIP_BASE_URL=https://global-live.mux.com/api/v1/whip

# YouTube — already present from Sprint 5; this only adds the RTMP URL.
YOUTUBE_RTMP_URL=rtmp://a.rtmp.youtube.com/live2

# ────────────────────────────────────────────────────────────────────
#  After editing .env, clear the config cache:
#  D:\xamp new\htdocs\Dawri\backend>  php artisan config:clear
# ────────────────────────────────────────────────────────────────────
